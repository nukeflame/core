{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "barryvdh/laravel-dompdf": "^2.1",
        "bensampo/laravel-enum": "^6.12",
        "doctrine/dbal": "^3.9",
        "geekcom/phpjasper": "^3.4",
        "google/apiclient": "^2.18",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^10.10",
        "laravel/horizon": "^5.30",
        "laravel/passport": "^11.0",
        "laravel/reverb": "^1.4",
        "laravel/sanctum": "^3.3",
        "laravel/tinker": "^2.8",
        "league/flysystem-aws-s3-v3": "^3.0",
        "league/oauth2-client": "^2.8",
        "league/oauth2-google": "^4.0",
        "maatwebsite/excel": "^3.1",
        "mews/purifier": "^3.4",
        "microsoft/microsoft-graph": "^2.42",
        "php-imap/php-imap": "^5.0",
        "phpoffice/phpspreadsheet": "^1.29.9",
        "phpoffice/phpword": "^1.3",
        "prettus/l5-repository": "^2.9",
        "spatie/laravel-html": "^3.5.0",
        "spatie/laravel-permission": "^6.3",
        "symfony/css-selector": "^6.4.13",
        "symfony/dom-crawler": "^6.4.19",
        "thenetworg/oauth2-azure": "^2.2",
        "webklex/laravel-imap": "^6.2",
        "yajra/laravel-datatables-oracle": "^10.11",
        "nukeflame/webmatics": "@dev"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/breeze": "^1.28",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Nukeflame\\Webmatics\\": "vendor/nukeflame/src/"
        },
        "files": [
            "app/Http/Helpers/HelperMethods.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../nukeflame/webmatics"
        }
    ]
}
